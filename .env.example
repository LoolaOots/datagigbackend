# App
APP_ENV=development
SECRET_KEY=changeme

# Supabase (same project as datagigwebsite)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (same Supabase Postgres as datagigwebsite — session mode pooler)
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Resend
RESEND_API_KEY=your-resend-api-key

# Supabase JWT secret (Settings > API > JWT Secret in dashboard)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Internal auth (shared secret for website → backend calls)
INTERNAL_API_SECRET=changeme

